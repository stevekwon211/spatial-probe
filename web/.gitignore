.vercel
/.next
/node_modules
# local env — secrets (Vercel/Turbo tokens); never commit
.env
.env*.local
# 381MB occquery 3D-viewer scene data — never commit (degrades gracefully on Vercel)
/public/data/occquery
# The small Aletheon demo frame images ARE committed (CDN static, ~744KB, referenced as /data/frames/*)
*.tsbuildinfo

# projective-texturing camera images + params (derived from gitignored data/samples, local-only)
/public/occ/cams/
/public/occ/*.cams.json
# LiDAR-accumulated reconstruction dims sidecar (the .bin is covered by *.bin; both derived, local-only)
/public/occ/*.lidar02.json
