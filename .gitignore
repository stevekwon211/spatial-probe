# datasets & model weights — never committed.
# Anchored to repo root so it ONLY hides the top-level Python dataset dir; the web demo
# data under web/public/data is governed by web/.gitignore (occquery ignored, frames committed).
/data/
*.pth
*.ckpt
*.npz
*.bin

# experiment outputs (keep hand-written *summary.md, ignore raw dumps)
experiments/**/results/*
!experiments/**/results/*summary.md

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# web (Next.js)
web/node_modules/
web/.next/
web/out/
web/.vercel/
web/next-env.d.ts

# os / editor
.DS_Store
.idea/
.vscode/
